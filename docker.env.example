# Copy to `.env` in the same directory as `docker-compose.yml` and customize.
# `.env` is gitignored — do not commit real passwords.
#
# The stock image starts Mosquitto inside the container and defaults to
# MQTT_HOST=0.0.0.0 / MQTT_PORT=1885 for the app to talk to that broker.
# To point the app at another broker (e.g. Home Assistant), set host/port/user/pass
# below — you may still need a custom image or start.sh to skip the embedded broker.

MQTT_HOST=0.0.0.0
MQTT_PORT=1885

# Optional MQTT auth (client credentials when connecting to a broker that requires them)
# MQTT_USERNAME=ampbridge
# MQTT_PASSWORD=

# MQTT_BASE_TOPIC=ampbridge/zones

# Production: set a real secret (mix phx.gen.secret); required for serious deployments
# SECRET_KEY_BASE=
