#!/bin/sh
# Pre-commit hook: blocks commit if Elixir code is not formatted.
# Install with: mix install_hooks (or mix setup)

cd AmpBridge && mix format --check-formatted
exit_code=$?

if [ $exit_code -ne 0 ]; then
  echo ""
  echo "❌ Commit blocked: code is not formatted. Run 'mix format' in AmpBridge/ and try again."
  exit 1
fi

exit 0
